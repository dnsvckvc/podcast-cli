{
  "salad": {
    "verbose": true,
    "storage_base_url": "https://storage-api.salad.com/organizations",
    "transcript_base_url": "https://api.salad.com/api/public/organizations",
    "max_direct_upload": 104857600,
    "base_dir": "/tmp",
    "downloads_dir": "audio",
    "transcription_extension": ".txt",
    "use_lite": false,
    "language_code": "en",
    "diarization": true,
    "sentence_level_timestamps": true,
    "poll_interval_s": 10,
    "max_poll_minutes": 90
  },
  "youtube": {
    "verbose": true,
    "file_ext": ".mp3",
    "metadata_ext": ".info.json",
    "downloads_dir": "audio",
    "base_dir": "/tmp"
  },
  "rss_feed": {
    "verbose": true,
    "chunk_size": 8192,
    "file_ext": ".mp3",
    "base_dir": "/tmp",
    "downloads_dir": "audio"
  }
}
