# Podcast CLI Environment Variables

# OpenAI API (required for summarization)
OPENAI_API_KEY=your_openai_api_key_here

# Salad AI Transcription Service (required for remote/hybrid modes)
SALAD_API_KEY=your_salad_api_key_here
SALAD_ORGANIZATION=your_salad_organization_here

# Remote API Authentication (required for --remote mode)
API_USERNAME=admin
API_PASSWORD=your_secure_password_here
API_URL=https://your-api-endpoint.hf.space
